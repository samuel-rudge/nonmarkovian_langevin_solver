# File types to ignore 
# -----------------------

# Raw data files
*.dat
*.out
*.bin

# Logs
*.log

# Temporary files
*.tmp
*.temp
*.bak

# Python build/cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Jupyter notebook checkpoints
.ipynb_checkpoints/

# Virtual environments
venv/
.env/
.venv/

# Editor & OS files
.DS_Store
Thumbs.db

# VS Code settings
.vscode/
